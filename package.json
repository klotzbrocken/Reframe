{
  "name": "reframe",
  "version": "1.9.0",
  "description": "Reframe — today's web, yesterday's look. A modern Chromium browser wrapped in pixel-faithful retro chrome (IE5, Netscape, Aqua Safari).",
  "author": "Maik Klotz",
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "release": "electron-vite build && electron-builder --mac --publish always",
    "release:win": "electron-vite build && electron-builder --win --publish always",
    "package:linux": "electron-vite build && electron-builder --linux",
    "release:linux": "electron-vite build && electron-builder --linux --publish always",
    "test": "vitest run"
  },
  "build": {
    "appId": "app.myretromac.reframe",
    "productName": "Reframe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/@ghostery/**/*"
    ],
    "electronLanguages": [
      "en",
      "en_US",
      "en_GB",
      "en-US",
      "en-GB",
      "de"
    ],
    "extraResources": [
      "resources/**/*",
      "!resources/app-icons/reframe.icns",
      "!resources/app-icons/ie5.png",
      "!resources/app-icons/netscape.png"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "klotzbrocken",
        "repo": "Reframe"
      }
    ],
    "afterPack": "build/trim-locales.cjs",
    "afterSign": "build/notarize.cjs",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis"
        },
        {
          "target": "portable"
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Network",
      "synopsis": "Today's web, yesterday's look — a retro-chrome browser.",
      "target": [
        {
          "target": "AppImage"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Reframe"
    },
    "asarUnpack": [
      "node_modules/@ghostery/adblocker-electron-preload/**"
    ]
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "2.9.0",
    "@ghostery/adblocker-electron-preload": "2.18.1",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "98.css": "^0.1.21",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.9"
  }
}
